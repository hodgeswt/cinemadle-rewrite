{
    "NLog": {
        "autoReload": true,
        "throwConfigExceptions": true,
        "targets": {
            "logfile": {
                "type": "File",
                "fileName": "${specialfolder:folder=LocalApplicationData}/AppData/cinemadle.log",
                "layout": "${longdate} ${level} ${message} ${exception}"
            }
        },
        "rules": [  
            {
                "logger": "Cinemadle*",
                "minLevel": "Info",
                "writeTo": "logfile"
            }
        ]
    },
    "AllowedHosts": "*",
    "CinemadleConfig": {
        "TmdbApiKey": "testKey",
        "PaymentsApiKey": "testKey",
        "WebhookSecret": "testKey",
        "CastCount": 3,
        "CreativesCount": 3,
        "GenresCount": 3,
        "CacheTTL": 10800,
        "YearYellowThreshold": 5,
        "BoxOfficeYellowThreshold": 100000000,
        "YearSingleArrowThreshold": 10,
        "BoxOfficeSingleArrowThreshold": 300000000,
        "YearDoubleArrowThreshold": 15,
        "OldestMoviePossible": "1960-01-01",
        "MinimumVotesPossible": 2000,
        "MinimumScorePossible": 5,
        "MinimumRuntimePossible": 70,
        "MovieImageBlurFactors": {
            "6": 14.0,
            "7": 12.0,
            "8": 9.0,
            "9": 6.0
        },
        "GameLength": 10,
        "PaymentSuccessUrl": "http://localhost:5566/paymentSuccess.html",
        "PaymentFailureUrl": "http://localhost:5566/paymentFailure.html",
        "AddOnMapping": { },
        "FeatureFlags": {
            "PaymentsEnabled": false
        }
    }
}